{
  "name": "pottery-studio-manager",
  "version": "1.0.0",
  "description": "陶艺工作室管理系统 - 学员作品从制作到烧制的全流程管理",
  "main": "electron/main.js",
  "author": "Pottery Studio",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "vue": "^3.4.21",
    "element-plus": "^2.6.1",
    "@element-plus/icons-vue": "^2.3.1",
    "dayjs": "^1.11.10",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "vite": "^5.1.6",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.pottery.studio.manager",
    "productName": "陶艺工作室管理系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
